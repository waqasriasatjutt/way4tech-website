---
import { SITE, SERVICES } from '~/data/site';
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-ink-100 bg-ink-50">
  <div class="container-site py-14">
    <div class="grid gap-10 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 font-bold text-ink-900">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white text-sm">W4</span>
          <span class="text-lg">{SITE.name}</span>
        </div>
        <p class="mt-3 text-sm text-ink-600">
          Odoo customization, implementation, and support. Trusted by growing businesses across Pakistan and the GCC.
        </p>
      </div>

      <div>
        <div class="text-xs font-semibold uppercase tracking-wider text-ink-500">Services</div>
        <ul class="mt-3 space-y-2 text-sm text-ink-700">
          {SERVICES.slice(0, 6).map((s) => (
            <li><a class="hover:text-ink-950" href={`/services/${s.slug}/`}>{s.title}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <div class="text-xs font-semibold uppercase tracking-wider text-ink-500">Company</div>
        <ul class="mt-3 space-y-2 text-sm text-ink-700">
          <li><a class="hover:text-ink-950" href="/about/">About</a></li>
          <li><a class="hover:text-ink-950" href="/industries/">Industries</a></li>
          <li><a class="hover:text-ink-950" href="/products/">Products</a></li>
          <li><a class="hover:text-ink-950" href="/blog/">Blog</a></li>
          <li><a class="hover:text-ink-950" href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div>
        <div class="text-xs font-semibold uppercase tracking-wider text-ink-500">Contact</div>
        <ul class="mt-3 space-y-2 text-sm text-ink-700">
          <li><a class="hover:text-ink-950" href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li><a class="hover:text-ink-950" href={SITE.whatsapp}>WhatsApp: {SITE.phone}</a></li>
          <li class="text-ink-600">{SITE.locations.join(' · ')}</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between border-t border-ink-200 pt-6 text-xs text-ink-600">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <p>Built with Astro. Hosted on Cloudflare.</p>
    </div>
  </div>
</footer>
