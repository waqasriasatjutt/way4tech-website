---
import { SITE, SERVICES, SOLUTIONS, COUNTRIES, MODULES } from '~/data/site';
const year = new Date().getFullYear();
const topServices = SERVICES.slice(0, 8);
const topModules = MODULES.slice(0, 8);
const topSolutions = SOLUTIONS.slice(0, 8);
const topCountries = COUNTRIES.filter(c => ['saudi-arabia','uae','qatar','pakistan','india','united-kingdom','united-states','germany'].includes(c.slug));
---
<footer class="mt-24 bg-ink-900 text-ink-100">
  <div class="container-site py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <img src="/logo.svg" alt="Way4Tech" width="180" height="42" class="h-10 w-auto brightness-0 invert" />
        <p class="mt-4 text-sm text-ink-300 max-w-sm">
          Odoo Gold Partner with 9+ years of delivery, 500+ deployments, 1000+ custom modules across 18 countries.
        </p>
        <div class="mt-6 space-y-2 text-sm">
          <a class="block text-ink-300 hover:text-white" href={`mailto:${SITE.email}`}>✉ {SITE.email}</a>
          <a class="block text-ink-300 hover:text-white" href={SITE.whatsapp}>💬 WhatsApp {SITE.phone}</a>
          <a class="block text-ink-300 hover:text-white" href={SITE.social.linkedin} target="_blank" rel="noopener">in LinkedIn</a>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Services</div>
        <ul class="mt-4 space-y-2 text-sm text-ink-300">
          {topServices.map(s => (<li><a class="hover:text-white" href={`/services/${s.slug}/`}>{s.title}</a></li>))}
          <li><a class="hover:text-white font-semibold text-brand-200" href="/services/">All services →</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Modules</div>
        <ul class="mt-4 space-y-2 text-sm text-ink-300">
          {topModules.map(m => (<li><a class="hover:text-white" href={`/modules/${m.slug}/`}>{m.title}</a></li>))}
          <li><a class="hover:text-white font-semibold text-brand-200" href="/modules/">All 25 modules →</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Solutions</div>
        <ul class="mt-4 space-y-2 text-sm text-ink-300">
          {topSolutions.map(s => (<li><a class="hover:text-white" href={`/solutions/${s.slug}/`}>{s.title}</a></li>))}
          <li><a class="hover:text-white font-semibold text-brand-200" href="/solutions/">All solutions →</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Countries</div>
        <ul class="mt-4 space-y-2 text-sm text-ink-300">
          {topCountries.map(c => (<li><a class="hover:text-white" href={`/countries/${c.slug}/`}>{c.flag} {c.title}</a></li>))}
          <li><a class="hover:text-white font-semibold text-brand-200" href="/countries/">All 18 countries →</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-5 border-t border-white/10 pt-8 text-sm">
      <div><div class="text-xs font-bold uppercase tracking-wider text-brand-300">Products</div><a href="/products/" class="mt-3 block text-ink-300 hover:text-white">WT Odoo modules →</a></div>
      <div><div class="text-xs font-bold uppercase tracking-wider text-brand-300">Integrations</div><a href="/integrations/" class="mt-3 block text-ink-300 hover:text-white">20+ integrations →</a></div>
      <div><div class="text-xs font-bold uppercase tracking-wider text-brand-300">Case Studies</div><a href="/case-studies/" class="mt-3 block text-ink-300 hover:text-white">Client stories →</a></div>
      <div><div class="text-xs font-bold uppercase tracking-wider text-brand-300">Company</div><a href="/about/" class="mt-3 block text-ink-300 hover:text-white">About us →</a><a href="/careers/" class="mt-1 block text-ink-300 hover:text-white">Careers →</a></div>
      <div><div class="text-xs font-bold uppercase tracking-wider text-brand-300">Resources</div><a href="/resources/" class="mt-3 block text-ink-300 hover:text-white">Guides & FAQ →</a><a href="/blog/" class="mt-1 block text-ink-300 hover:text-white">Blog →</a></div>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between border-t border-white/10 pt-6 text-xs text-ink-400 gap-3">
      <p>© {year} {SITE.name}. Odoo Gold Partner. All rights reserved.</p>
      <p>Built with Astro · Hosted on Cloudflare · Secured by SSL.</p>
    </div>
  </div>
</footer>
