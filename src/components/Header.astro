---
import { SITE } from '~/data/site';
---
<header class="sticky top-0 z-40 border-b border-ink-100 bg-white/80 backdrop-blur-md">
  <div class="container-site flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-ink-900">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white text-sm">W4</span>
      <span class="text-lg">{SITE.name}</span>
    </a>

    <nav class="hidden lg:flex items-center gap-7 text-sm font-medium text-ink-700">
      <a href="/services/" class="hover:text-ink-950">Services</a>
      <a href="/products/" class="hover:text-ink-950">Products</a>
      <a href="/industries/" class="hover:text-ink-950">Industries</a>
      <a href="/about/" class="hover:text-ink-950">About</a>
      <a href="/blog/" class="hover:text-ink-950">Blog</a>
    </nav>

    <div class="flex items-center gap-2">
      <a href={SITE.whatsapp} target="_blank" rel="noopener" class="hidden sm:inline-flex btn-ghost text-sm">WhatsApp</a>
      <a href="/contact/" class="btn-primary text-sm">Get a Quote</a>
    </div>
  </div>
</header>
