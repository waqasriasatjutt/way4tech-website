---
import { SITE } from '~/data/site';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  structuredData?: object | object[];
}

const {
  title,
  description = SITE.description,
  image = '/og.png',
  canonical,
  structuredData,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalURL = canonical || new URL(Astro.url.pathname, SITE.url).toString();
const imageURL = new URL(image, SITE.url).toString();

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  legalName: 'Way4Tech',
  url: SITE.url,
  logo: new URL('/logo.svg', SITE.url).toString(),
  description: SITE.description,
  foundingDate: '2016',
  slogan: 'Odoo Gold Partner — implementation, customization, SaaS, support.',
  areaServed: SITE.locations,
  contactPoint: [{
    '@type': 'ContactPoint',
    email: SITE.email,
    telephone: SITE.phone,
    contactType: 'sales',
    availableLanguage: ['English', 'Arabic', 'Urdu'],
  }],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127',
    bestRating: '5',
  },
  sameAs: [SITE.social.linkedin, SITE.social.github],
};

const sdArray = [orgSchema, ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [])];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#714B67" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="keywords" content="Odoo, Odoo partner, Odoo Gold Partner, Odoo implementation, Odoo customization, Odoo ERP, Odoo Saudi Arabia, Odoo UAE, Odoo Qatar, Odoo Kuwait, Odoo Oman, Odoo Bahrain, Odoo Pakistan, Odoo India, Odoo Turkey, Odoo Egypt, Odoo Jordan, Odoo UK, Odoo Germany, Odoo France, Odoo USA, Odoo Canada, Odoo Australia, Odoo developer, Odoo SaaS, Odoo HRMS, Odoo Payroll, Odoo POS, Odoo MRP, Odoo manufacturing, Odoo hospital management, Odoo clinic, Odoo pharmacy, Odoo restaurant, Odoo retail, Odoo construction, Odoo real estate, Odoo school, Odoo logistics, ZATCA Phase 2, FBR POS, GST e-invoicing, ERP Riyadh, ERP Jeddah, ERP Dubai, ERP Abu Dhabi, ERP Doha, ERP Kuwait City, ERP Karachi, ERP Lahore, ERP Mumbai, ERP London, ERP Berlin, hire Odoo developer" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    {sdArray.map((sd) => (
      <script type="application/ld+json" set:html={JSON.stringify(sd)} />
    ))}
  </head>
  <body class="min-h-screen bg-white text-ink-900 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
