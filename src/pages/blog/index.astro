---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchOdooBlogPosts } from '~/lib/odoo';

const mdx = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .map(p => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    author: p.data.author,
    date: p.data.date,
    tags: p.data.tags,
    source: 'mdx' as const,
  }));

const odoo = (await fetchOdooBlogPosts()).map(p => ({
  slug: p.slug,
  title: p.title,
  description: p.teaser || p.subtitle || p.title,
  author: p.author,
  date: p.postDate,
  tags: p.tags,
  source: 'odoo' as const,
}));

const posts = [...mdx, ...odoo].sort((a, b) => b.date.getTime() - a.date.getTime());
---
<Base title="Blog — Odoo, ERP, and SaaS Engineering" description="Insights on Odoo implementation, ERP strategy, and SaaS operations from the Way4Tech engineering team.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Blog</div>
        <h1 class="h1 mt-4">Writing on Odoo, ERP, and SaaS.</h1>
        <p class="lede mt-6 text-ink-300">Practical, honest writing from engineers who ship. Authored directly from our Odoo portal — published instantly to the website.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      {posts.length === 0 ? (
        <p class="text-ink-600">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map(post => (
            <a href={`/blog/${post.slug}/`} class="card group flex flex-col">
              <div class="flex gap-2 flex-wrap items-center">
                {post.tags.map(t => <span class="text-xs font-medium text-brand-700 bg-brand-50 rounded-full px-2.5 py-0.5">{t}</span>)}
                {post.source === 'odoo' && <span class="text-[10px] font-semibold uppercase tracking-wider text-accent-600">Fresh from Odoo</span>}
              </div>
              <h2 class="mt-4 text-xl font-semibold">{post.title}</h2>
              <p class="mt-3 text-sm text-ink-600 flex-1">{post.description}</p>
              <div class="mt-5 flex items-center justify-between text-xs text-ink-500">
                <span>{post.author}</span>
                <time datetime={post.date.toISOString()}>{post.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
