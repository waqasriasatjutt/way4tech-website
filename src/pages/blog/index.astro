---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title="Blog — Odoo, ERP, and SaaS Engineering" description="Insights on Odoo implementation, ERP strategy, and SaaS operations from the Way4Tech engineering team.">
  <section class="bg-gradient-to-br from-brand-950 to-brand-800 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-200">Blog</div>
        <h1 class="h1 mt-4">Writing on Odoo, ERP, and SaaS.</h1>
        <p class="lede mt-6 text-ink-100">Practical, honest writing from engineers who ship. No SEO fluff, no keyword stuffing — just things we've actually learned in production.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`} class="card group flex flex-col">
            <div class="flex gap-2 flex-wrap">
              {post.data.tags.map(t => <span class="text-xs font-medium text-brand-700 bg-brand-50 rounded-full px-2.5 py-0.5">{t}</span>)}
            </div>
            <h2 class="mt-4 text-xl font-semibold">{post.data.title}</h2>
            <p class="mt-3 text-sm text-ink-600 flex-1">{post.data.description}</p>
            <div class="mt-5 flex items-center justify-between text-xs text-ink-500">
              <span>{post.data.author}</span>
              <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
