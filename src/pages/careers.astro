---
import Base from '~/layouts/Base.astro';

const roles = [
  { title: 'Senior Odoo Developer (Python + OWL)', type: 'Full-time · Remote', desc: '5+ years Odoo. Deep Python, PostgreSQL, and OWL framework experience. You will own modules end-to-end.' },
  { title: 'Odoo Functional Consultant', type: 'Full-time · Remote', desc: '4+ years functional Odoo. Lead discovery, design workflows, run UAT, train users — across industries.' },
  { title: 'Odoo Project Manager', type: 'Full-time · Remote', desc: 'Run multi-country Odoo rollouts. Stakeholder communication, scope control, delivery discipline.' },
  { title: 'DevOps / SRE (Odoo)', type: 'Full-time · Remote', desc: 'Docker, PostgreSQL, Cloudflare, Nginx. Multi-tenant SaaS operations, backups, monitoring.' },
  { title: 'QA Engineer (Odoo)', type: 'Full-time · Remote', desc: 'Automated and manual QA for Odoo modules. pytest, tours, regression suites.' },
  { title: 'Business Development (GCC)', type: 'Full-time · Riyadh/Dubai', desc: 'Own pipeline in KSA, UAE, Qatar. Consultative sales, 5+ years in enterprise software.' },
];
---
<Base title="Careers — Work with Way4Tech" description="Careers at Way4Tech. Remote-first, senior-only Odoo roles. Python, OWL, functional consulting, project management, DevOps, QA, BD.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Careers</div>
        <h1 class="h1 mt-4">Senior engineers. Real ownership. No BS.</h1>
        <p class="lede mt-6 text-ink-300">We hire experienced Odoo people and give them room to do their best work. Remote-first with meet-ups in Dubai and Karachi.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <h2 class="h3">Open roles</h2>
      <div class="mt-8 space-y-4">
        {roles.map(r => (
          <div class="card flex flex-col sm:flex-row sm:items-center justify-between gap-5">
            <div>
              <h3 class="font-semibold text-lg">{r.title}</h3>
              <p class="mt-1 text-xs text-brand-600 font-semibold">{r.type}</p>
              <p class="mt-2 text-sm text-ink-600">{r.desc}</p>
            </div>
            <a href="/contact/" class="btn-primary shrink-0">Apply</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50 border-t border-ink-100">
    <div class="container-site max-w-3xl text-center">
      <h2 class="h2">Don't see your role?</h2>
      <p class="lede mt-4">We're always hiring exceptional Odoo people. Send us a note with your focus area and we'll find a fit.</p>
      <a href="/contact/" class="btn-primary mt-8">Send us your resume</a>
    </div>
  </section>
</Base>
