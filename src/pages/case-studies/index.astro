---
import Base from '~/layouts/Base.astro';
import { CASE_STUDIES } from '~/data/site';
---
<Base title="Case Studies — Odoo deployments at scale" description="Real-world Odoo case studies from hotel chains, pharmacy networks, FMCG distributors, hospitals, construction groups, and retail chains.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Case Studies</div>
        <h1 class="h1 mt-4">Real deployments. Real numbers.</h1>
        <p class="lede mt-6 text-ink-300">500+ go-lives across hospitality, healthcare, distribution, construction, and retail.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {CASE_STUDIES.map(cs => (
          <a href={`/case-studies/${cs.slug}/`} class="card group">
            <div class="flex items-center gap-2 text-xs">
              <span class="chip">{cs.industry}</span>
              <span class="chip">{cs.country}</span>
            </div>
            <h2 class="mt-3 font-semibold text-lg">{cs.title}</h2>
            <p class="mt-2 text-sm text-ink-600">{cs.tagline}</p>
            <div class="mt-4 flex flex-wrap gap-4 text-sm">
              {cs.metrics.map(m => (<span><span class="font-bold text-brand-700">{m.v}</span> <span class="text-ink-500">{m.k}</span></span>))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
