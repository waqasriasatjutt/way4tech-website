---
import Base from '~/layouts/Base.astro';
import { SITE } from '~/data/site';
---
<Base title="Contact" description="Get in touch with Way4Tech. Free 30-minute consultation for new projects. Email, WhatsApp, or book a call.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Contact</div>
        <h1 class="h1 mt-4">Let's talk about your project.</h1>
        <p class="lede mt-6 text-ink-300">Free 30-minute consultation. No obligation, no sales pitch — just an honest conversation about what you're trying to build.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-14 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <h2 class="h3">Send us a message</h2>
          <p class="mt-3 text-ink-600">We respond within 4 business hours.</p>

          <form id="contactForm" class="mt-8 space-y-5">
            <!-- honeypot -->
            <input type="text" name="_hp" tabindex="-1" autocomplete="off" class="absolute left-[-9999px] w-0 h-0 opacity-0" aria-hidden="true" />
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="block text-sm font-medium text-ink-800">Your name *</label>
                <input type="text" name="name" required class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none" />
              </div>
              <div>
                <label class="block text-sm font-medium text-ink-800">Company</label>
                <input type="text" name="company" class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none" />
              </div>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="block text-sm font-medium text-ink-800">Email *</label>
                <input type="email" name="email" required class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none" />
              </div>
              <div>
                <label class="block text-sm font-medium text-ink-800">Phone / WhatsApp</label>
                <input type="tel" name="phone" class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-ink-800">What do you need? *</label>
              <select name="service" required class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none bg-white">
                <option value="">Select a service</option>
                <option>New Odoo implementation</option>
                <option>Custom module / customization</option>
                <option>Odoo support / maintenance</option>
                <option>Hire Odoo developer</option>
                <option>Migration / upgrade</option>
                <option>Integration with existing systems</option>
                <option>Product inquiry (specific module)</option>
                <option>Other / consultation</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-ink-800">Tell us about your project *</label>
              <textarea name="message" rows="5" required class="mt-1.5 w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none"></textarea>
            </div>

            <button type="submit" class="btn-primary" id="submitBtn">Send message</button>
            <p class="text-xs text-ink-500">We'll never share your info. Reply within 4 business hours.</p>

            <div id="formResult" class="hidden"></div>
          </form>
        </div>

        <aside class="lg:col-span-2">
          <div class="space-y-6">
            <div class="rounded-2xl border border-ink-200 bg-white p-6">
              <h3 class="text-sm font-semibold">Direct contact</h3>
              <ul class="mt-4 space-y-3 text-sm">
                <li><a class="text-ink-700 hover:text-brand-600" href={`mailto:${SITE.email}`}>✉ {SITE.email}</a></li>
                <li><a class="text-ink-700 hover:text-brand-600" href={`mailto:${SITE.alt_email}`}>✉ {SITE.alt_email}</a></li>
                <li><a class="text-ink-700 hover:text-brand-600" href={SITE.whatsapp} target="_blank" rel="noopener">📱 WhatsApp {SITE.phone}</a></li>
                <li><a class="text-ink-700 hover:text-brand-600" href={`tel:${SITE.phone.replace(/\s/g,'')}`}>📞 {SITE.phone}</a></li>
              </ul>
            </div>

            <div class="rounded-2xl bg-ink-50 p-6">
              <h3 class="text-sm font-semibold">Service areas</h3>
              <ul class="mt-4 space-y-2 text-sm text-ink-700">
                {SITE.locations.map((l) => <li>📍 {l}</li>)}
              </ul>
              <p class="mt-4 text-xs text-ink-600">Remote-first with on-site visits available for major rollouts.</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      const form = document.getElementById('contactForm');
      const result = document.getElementById('formResult');
      const btn = document.getElementById('submitBtn');
      if (!form) return;

      // Prefill ?product= / ?service= / ?country= from URL
      const qs = new URLSearchParams(location.search);
      ['product','service','country','source'].forEach(k => {
        const v = qs.get(k);
        if (v) {
          let input = form.querySelector('input[name="' + k + '"]');
          if (!input) {
            input = document.createElement('input');
            input.type = 'hidden';
            input.name = k;
            form.appendChild(input);
          }
          input.value = v;
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = 'Sending...';
        const fd = new FormData(form);
        const data = Object.fromEntries(fd.entries());
        data.website = location.href;
        try {
          const resp = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(data),
          });
          const j = await resp.json().catch(() => ({}));
          if (resp.ok && j.ok) {
            result.className = 'rounded-lg bg-green-50 border border-green-200 p-4 text-sm text-green-900';
            result.textContent = 'Thanks! We got your message and will reply within 4 business hours.';
            form.reset();
          } else {
            throw new Error(j.error || 'Network error');
          }
        } catch (err) {
          result.className = 'rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-900';
          result.textContent = 'Could not submit right now. Please email info@way4tech.com or WhatsApp us.';
        }
        result.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Send message';
      });
    })();
  </script>
</Base>
