---
import Base from '~/layouts/Base.astro';
import { COUNTRIES } from '~/data/site';
---
<Base title="Countries — Odoo partner in 18 countries" description="Way4Tech delivers Odoo ERP across 18 countries — Saudi Arabia, UAE, Qatar, Kuwait, Oman, Bahrain, Pakistan, India, Turkey, UK, Germany, USA and more.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Global Odoo Partner</div>
        <h1 class="h1 mt-4">Localized Odoo — 18 countries and counting.</h1>
        <p class="lede mt-6 text-ink-300">From ZATCA in Saudi Arabia to MTD VAT in the UK — we ship Odoo with compliance, tax, and payroll localized out of the box.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {COUNTRIES.map(c => (
          <a href={`/countries/${c.slug}/`} class="card group">
            <div class="flex items-center gap-3 text-3xl">
              <span>{c.flag}</span>
              <h2 class="text-lg font-semibold text-ink-900">{c.title}</h2>
            </div>
            <p class="mt-3 text-sm text-ink-600">{c.tagline}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {c.cities.slice(0,4).map(city => <span class="chip text-[10px]">{city}</span>)}
            </div>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 group-hover:text-brand-700">Odoo in {c.title} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
