---
import Base from '~/layouts/Base.astro';
import { SITE, SERVICES, PRODUCTS, INDUSTRIES, STATS, HIGHLIGHTS, MODULES, SOLUTIONS, COUNTRIES, FAQS, CASE_STUDIES, INTEGRATIONS } from '~/data/site';

const featuredProducts = PRODUCTS.filter(p => ['wt-hrms-core','wt-saas-odoo-kit','wt-sale-dashboard','wt-salon-management','wt-pos-saloon','way4tech-logistics'].includes(p.slug));
const featuredModules = MODULES.slice(0, 12);
const featuredSolutions = SOLUTIONS.slice(0, 9);
const featuredCountries = COUNTRIES.filter(c => ['saudi-arabia','uae','qatar','pakistan','india','united-kingdom','united-states','germany'].includes(c.slug));
const featuredIntegrations = INTEGRATIONS.slice(0, 12);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<Base
  title="Odoo Gold Partner — Implementation, Customization, SaaS"
  description="Way4Tech is an Odoo Gold Partner with 9+ years, 500+ deployments, 1000+ custom modules across 18 countries. Implementation, customization, ZATCA, HRMS, POS, SaaS."
  structuredData={faqSchema}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-ink-900 text-white">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 15% 10%, rgba(135,90,123,0.55) 0%, transparent 45%), radial-gradient(circle at 85% 90%, rgba(0,160,157,0.35) 0%, transparent 50%), linear-gradient(180deg, #1a1230 0%, #110a20 100%);"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22><path d=%22M30 2L56 17v26L30 58 4 43V17z%22 fill=%22none%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"></div>
    <div class="container-site relative py-24 sm:py-32 lg:py-40">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold backdrop-blur">
          <span class="inline-block h-2 w-2 rounded-full bg-accent-400 animate-pulse"></span>
          Odoo Gold Partner · Serving 18 countries
        </div>
        <h1 class="h1 mt-6 tracking-tight">
          The <span class="bg-gradient-to-r from-brand-300 to-accent-300 bg-clip-text text-transparent">Odoo ERP</span> your business deserves.
        </h1>
        <p class="lede mt-6 text-ink-200 max-w-3xl">
          We design, build, and run Odoo for ambitious companies. 9+ years of delivery, 500+ go-lives, 1000+ custom modules — from Riyadh to Berlin.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="btn-primary bg-white !text-brand-700 hover:bg-brand-50">Get a free consultation</a>
          <a href="/modules/" class="btn-secondary !bg-white/5 !border-white/20 !text-white hover:!bg-white/10">Explore 25 Odoo modules</a>
        </div>

        <div class="mt-14 grid grid-cols-2 gap-6 sm:grid-cols-4 max-w-3xl">
          {STATS.map(s => (
            <div>
              <div class="text-3xl sm:text-4xl font-bold text-white">{s.value}</div>
              <div class="text-sm text-ink-300 mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- trust strip -->
    <div class="relative border-t border-white/10">
      <div class="container-site py-5 flex flex-wrap items-center gap-x-10 gap-y-3 text-xs text-ink-300">
        <span class="font-semibold text-white">Trusted in:</span>
        {featuredCountries.map(c => (
          <a href={`/countries/${c.slug}/`} class="hover:text-white flex items-center gap-1.5">
            <span>{c.flag}</span><span>{c.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {HIGHLIGHTS.map(h => (
          <div class="card">
            <div class="text-3xl">{h.icon}</div>
            <h3 class="mt-3 text-lg font-semibold">{h.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section bg-ink-50 border-y border-ink-100">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="max-w-2xl">
          <div class="eyebrow">Services</div>
          <h2 class="h2 mt-3">Every Odoo service you need — under one roof.</h2>
          <p class="lede mt-4">From discovery to SaaS hosting, ZATCA e-invoicing to OWL custom modules. 15 productized services, 9+ years of practice.</p>
        </div>
        <a href="/services/" class="btn-secondary self-start">All 15 services →</a>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {SERVICES.slice(0, 9).map(s => (
          <a href={`/services/${s.slug}/`} class="card group flex flex-col">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{s.icon}</span>
              <span class="chip">{s.category}</span>
            </div>
            <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-600 flex-1">{s.tagline}</p>
            <span class="mt-4 text-sm font-semibold text-brand-600 group-hover:text-brand-700">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="max-w-2xl">
          <div class="eyebrow">Odoo Modules</div>
          <h2 class="h2 mt-3">25 Odoo ERP modules. One dedicated page each.</h2>
          <p class="lede mt-4">Sales, CRM, Inventory, MRP, Accounting, Payroll — we've deployed every core Odoo module at production scale.</p>
        </div>
        <a href="/modules/" class="btn-secondary self-start">Browse all modules →</a>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {featuredModules.map(m => (
          <a href={`/modules/${m.slug}/`} class="card group !p-5">
            <div class="flex items-center gap-2">
              <span class="text-2xl">{m.icon}</span>
              <span class="chip text-[10px]">{m.category}</span>
            </div>
            <h3 class="mt-3 text-base font-semibold">{m.title}</h3>
            <p class="mt-1.5 text-xs text-ink-600 leading-snug">{m.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUTIONS -->
  <section class="section bg-odoo-gradient text-white">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-brand-200">Industry Solutions</div>
          <h2 class="h2 mt-3 text-white">Tailored for your industry.</h2>
          <p class="lede mt-4 text-brand-100">20 industry-ready Odoo solutions built from hundreds of real deployments — hospitals, restaurants, construction, schools, and more.</p>
        </div>
        <a href="/solutions/" class="btn-secondary self-start !bg-white !text-brand-700 hover:!bg-brand-50">All 20 solutions →</a>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredSolutions.map(s => (
          <a href={`/solutions/${s.slug}/`} class="card-dark group">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{s.icon}</span>
              <h3 class="text-lg font-semibold text-white">{s.title}</h3>
            </div>
            <p class="mt-3 text-sm text-brand-100 leading-snug">{s.tagline}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-accent-300 group-hover:text-accent-200">Details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="max-w-2xl">
          <div class="eyebrow">Our Odoo modules</div>
          <h2 class="h2 mt-3">30+ production-ready Odoo add-ons.</h2>
          <p class="lede mt-4">Battle-tested modules: HRMS suite, SaaS Kit, dashboards, industry POS — all listed on the Odoo Apps Store.</p>
        </div>
        <a href="/products/" class="btn-secondary self-start">All products →</a>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {featuredProducts.map(p => (
          <a href={`/products/${p.slug}/`} class="card group">
            <div class="text-xs font-semibold uppercase tracking-wider text-brand-600">{p.category}</div>
            <h3 class="mt-2 text-lg font-semibold">{p.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{p.tagline}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 group-hover:text-brand-700">Details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDIES -->
  <section class="section bg-ink-50 border-y border-ink-100">
    <div class="container-site">
      <div class="max-w-2xl">
        <div class="eyebrow">Proof at scale</div>
        <h2 class="h2 mt-3">Real deployments. Real numbers.</h2>
        <p class="lede mt-4">500+ go-lives across hotels, hospitals, pharmacies, construction, distribution, and more.</p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {CASE_STUDIES.slice(0,6).map(cs => (
          <a href={`/case-studies/${cs.slug}/`} class="card group">
            <div class="flex items-center gap-2 text-xs">
              <span class="chip">{cs.industry}</span>
              <span class="chip">{cs.country}</span>
            </div>
            <h3 class="mt-3 font-semibold">{cs.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{cs.tagline}</p>
            <div class="mt-4 flex gap-4 text-sm">
              {cs.metrics.map(m => (
                <span><span class="font-bold text-brand-700">{m.v}</span> <span class="text-ink-500">{m.k}</span></span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="max-w-2xl">
        <div class="eyebrow">Integrations</div>
        <h2 class="h2 mt-3">Connected to the tools you already use.</h2>
        <p class="lede mt-4">Payment gateways, shipping carriers, eCommerce, CRM, BI, biometrics — 20+ pre-built Odoo integrations.</p>
      </div>
      <div class="mt-10 grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {featuredIntegrations.map(i => (
          <a href="/integrations/" class="card !p-4 flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-700 font-bold">{i.title.substring(0,2).toUpperCase()}</span>
            <span>
              <span class="block font-semibold text-sm">{i.title}</span>
              <span class="block text-xs text-ink-500">{i.category}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center"><a href="/integrations/" class="btn-secondary">See all 20 integrations →</a></div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section bg-ink-900 text-white">
    <div class="container-site">
      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <div class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-brand-300">Why Way4Tech</div>
          <h2 class="h2 mt-3 text-white">We write code. We ship. We stay.</h2>
          <p class="lede mt-4 text-ink-300">
            Odoo partners come and go. We build long-term relationships — some clients for 5+ years. Here's what makes the difference.
          </p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          {[
            { t:'Senior engineers only', d:'Every project led by engineers with 5+ years of Odoo. No juniors learning on your dime.' },
            { t:'Own the outcome', d:'We deploy, monitor, and fix. If something breaks in production, we own it.' },
            { t:'Transparent pricing', d:'Fixed-price scopes or honest T&M. No surprise invoices, ever.' },
            { t:'Direct access', d:'Slack/WhatsApp with the engineer writing your code. No PM middleman.' },
            { t:'Compliance-first', d:'ZATCA, FBR, GST, MTD, WPS — localization baked in, not bolted on.' },
            { t:'Stack agnostic', d:'On-prem, Docker, Kubernetes, Odoo.sh — we deploy where you need.' },
          ].map(x => (
            <div class="card-dark">
              <h3 class="font-semibold text-white">{x.t}</h3>
              <p class="mt-2 text-sm text-ink-300">{x.d}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container-site">
      <div class="grid gap-10 lg:grid-cols-3">
        <div>
          <div class="eyebrow">Questions</div>
          <h2 class="h2 mt-3">You ask. We answer.</h2>
          <p class="lede mt-4">Can't find an answer? <a href="/contact/" class="text-brand-600 underline">Ask directly</a>.</p>
        </div>
        <div class="lg:col-span-2 space-y-3">
          {FAQS.map(f => (
            <details class="group rounded-xl border border-ink-200 bg-white open:bg-brand-50/30 open:border-brand-200">
              <summary class="flex cursor-pointer items-center justify-between p-5 font-semibold">
                <span>{f.q}</span>
                <span class="text-brand-600 transition group-open:rotate-45">+</span>
              </summary>
              <p class="px-5 pb-5 text-ink-700">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-site">
      <div class="relative overflow-hidden rounded-3xl bg-odoo-gradient p-10 sm:p-16 text-white">
        <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-accent-400/30 blur-3xl"></div>
        <div class="absolute -bottom-16 -left-10 h-60 w-60 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative max-w-2xl">
          <h2 class="h2 text-white">Let's scope your Odoo project.</h2>
          <p class="lede mt-4 text-brand-100">Free 30-minute consultation. We'll review your current stack, identify gaps, and propose a path forward — no commitment.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-primary bg-white !text-brand-700 hover:bg-brand-50">Start a project</a>
            <a href={SITE.whatsapp} target="_blank" rel="noopener" class="btn-secondary !bg-white/10 !border-white/30 !text-white hover:!bg-white/20">WhatsApp us</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
