---
import Base from '~/layouts/Base.astro';
import { SITE, SERVICES, PRODUCTS, INDUSTRIES, STATS } from '~/data/site';

const featuredProducts = PRODUCTS.filter(p => ['wt-hrms-core','wt-saas-odoo-kit','wt-sale-dashboard','wt-salon-management','wt-pos-saloon','way4tech-logistics'].includes(p.slug));
---

<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 text-white">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 0%, #598aff 0%, transparent 40%), radial-gradient(circle at 80% 100%, #1e43ef 0%, transparent 40%);"></div>
    <div class="container-site relative py-20 sm:py-28 lg:py-36">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-200">Odoo Customization · Implementation · Support</div>
        <h1 class="h1 mt-4">Odoo ERP that fits your business — not the other way around.</h1>
        <p class="lede mt-6 text-ink-100">
          We build, customize, and support Odoo for businesses across Pakistan and the GCC. 20+ industry-ready modules. 6 years of delivery. One team that owns the outcome.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="btn-primary bg-white !text-brand-700 hover:bg-ink-100">Get a free consultation</a>
          <a href="/products/" class="btn-secondary !bg-transparent !border-white/30 !text-white hover:!bg-white/10">Browse products</a>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-6 sm:grid-cols-4 max-w-3xl">
        {STATS.map(s => (
          <div>
            <div class="text-3xl sm:text-4xl font-bold text-white">{s.value}</div>
            <div class="text-sm text-brand-200 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container-site">
      <div class="max-w-2xl">
        <div class="eyebrow">What we do</div>
        <h2 class="h2 mt-3">Full-stack Odoo services</h2>
        <p class="lede mt-4">From a single custom module to a multi-company, multi-country Odoo deployment — we handle every layer of the stack.</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} class="card group flex flex-col">
            <div class="text-3xl">{s.icon}</div>
            <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-600 flex-1">{s.tagline}</p>
            <span class="mt-4 text-sm font-medium text-brand-600 group-hover:text-brand-700">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="section bg-ink-50 border-y border-ink-100">
    <div class="container-site">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="max-w-2xl">
          <div class="eyebrow">Products</div>
          <h2 class="h2 mt-3">20+ Odoo modules. Ready to deploy.</h2>
          <p class="lede mt-4">Battle-tested modules covering HR, payroll, SaaS, POS, dashboards, and industry-specific workflows.</p>
        </div>
        <a href="/products/" class="btn-secondary self-start">See all products</a>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {featuredProducts.map(p => (
          <a href={`/products/${p.slug}/`} class="card group">
            <div class="text-xs font-semibold uppercase tracking-wider text-brand-600">{p.category}</div>
            <h3 class="mt-2 text-lg font-semibold">{p.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{p.tagline}</p>
            <span class="mt-4 inline-block text-sm font-medium text-brand-600 group-hover:text-brand-700">Details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="container-site">
      <div class="max-w-2xl">
        <div class="eyebrow">Industries</div>
        <h2 class="h2 mt-3">Expertise across industries</h2>
        <p class="lede mt-4">We don't just configure Odoo. We bring domain expertise from dozens of real deployments.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {INDUSTRIES.map(i => (
          <div class="card">
            <div class="text-3xl">{i.icon}</div>
            <h3 class="mt-3 text-base font-semibold">{i.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{i.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section bg-ink-950 text-white">
    <div class="container-site">
      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <div class="eyebrow text-brand-300">Why Way4Tech</div>
          <h2 class="h2 mt-3 text-white">We write code. We ship. We stay.</h2>
          <p class="lede mt-4 text-ink-300">
            Odoo partners come and go. We build long-term partnerships with our clients — some for 5+ years. Here's what makes us different.
          </p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          {[
            { t:'Senior engineers only', d:'Every project is led by engineers with 5+ years of Odoo experience. No juniors learning on your dime.' },
            { t:'Own the outcome', d:'We deploy, monitor, and fix. If something breaks in production, we own it — no finger-pointing.' },
            { t:'Transparent pricing', d:'Fixed-price scopes or honest T&M. No surprise invoices.' },
            { t:'Direct access', d:'Slack/WhatsApp with the engineer building your code. No account manager middleman.' },
          ].map(x => (
            <div class="rounded-xl border border-white/10 bg-white/5 p-5">
              <h3 class="font-semibold text-white">{x.t}</h3>
              <p class="mt-2 text-sm text-ink-300">{x.d}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-site">
      <div class="rounded-3xl bg-gradient-to-r from-brand-600 to-brand-800 p-10 sm:p-14 text-white">
        <div class="max-w-2xl">
          <h2 class="h2 text-white">Have a project? Let's talk.</h2>
          <p class="lede mt-4 text-brand-100">Tell us about your business and we'll scope a solution. Free consultation, no obligation.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact/" class="btn-primary bg-white !text-brand-700 hover:bg-ink-100">Start a project</a>
            <a href={SITE.whatsapp} target="_blank" rel="noopener" class="btn-secondary !bg-transparent !border-white/30 !text-white hover:!bg-white/10">WhatsApp us</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
