---
import Base from '~/layouts/Base.astro';
import { INDUSTRIES } from '~/data/site';
---
<Base title="Industries" description="Odoo solutions across retail, restaurant, healthcare, education, manufacturing, logistics, real estate, and services.">
  <section class="bg-gradient-to-br from-brand-950 to-brand-800 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-200">Industries</div>
        <h1 class="h1 mt-4">Deep expertise across industries.</h1>
        <p class="lede mt-6 text-ink-100">We don't just configure Odoo — we bring real deployment experience from dozens of clients across 8 industries.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {INDUSTRIES.map(i => (
          <div class="card">
            <div class="text-4xl">{i.icon}</div>
            <h3 class="mt-4 text-lg font-semibold">{i.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{i.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50 border-t border-ink-100">
    <div class="container-site">
      <div class="max-w-3xl">
        <h2 class="h2">Don't see your industry?</h2>
        <p class="lede mt-4">Odoo is flexible enough to model almost any business. We've delivered for cosmetics labs, printing presses, and language institutes. Tell us your use case.</p>
        <a href="/contact/" class="btn-primary mt-8">Talk to us</a>
      </div>
    </div>
  </section>
</Base>
