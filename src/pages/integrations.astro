---
import Base from '~/layouts/Base.astro';
import { INTEGRATIONS } from '~/data/site';

const byCat: Record<string, typeof INTEGRATIONS> = {};
INTEGRATIONS.forEach(i => { (byCat[i.category] ||= []).push(i); });
---
<Base title="Odoo Integrations — 20+ pre-built connectors" description="Pre-built Odoo integrations with Stripe, HyperPay, PayTabs, Razorpay, Aramex, DHL, Shopify, WooCommerce, Magento, Amazon, WhatsApp, Power BI, Salesforce, and more.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Integrations</div>
        <h1 class="h1 mt-4">Odoo, connected to everything.</h1>
        <p class="lede mt-6 text-ink-300">20+ pre-built connectors. Payments, shipping, eCommerce, CRM, BI, biometrics — or we'll build yours.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site space-y-12">
      {Object.entries(byCat).map(([cat, list]) => (
        <div>
          <h2 class="h3">{cat}</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {list.map(i => (
              <div class="card flex items-center gap-4">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-brand-100 text-brand-700 font-bold">{i.title.substring(0,2).toUpperCase()}</span>
                <div>
                  <h3 class="font-semibold">{i.title}</h3>
                  <p class="text-sm text-ink-600">{i.tagline}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section bg-ink-50 border-t border-ink-100">
    <div class="container-site text-center">
      <h2 class="h2">Don't see yours? We'll build it.</h2>
      <p class="lede mt-4 max-w-2xl mx-auto">Custom REST/GraphQL, webhook, EDI, or flat-file integrations — with retry, idempotency, and audit logging built in.</p>
      <a href="/contact/" class="btn-primary mt-8">Scope a custom integration</a>
    </div>
  </section>
</Base>
