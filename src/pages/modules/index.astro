---
import Base from '~/layouts/Base.astro';
import { MODULES } from '~/data/site';

const modByCat: Record<string, typeof MODULES> = {};
MODULES.forEach(m => { (modByCat[m.category] ||= []).push(m); });
---
<Base title="Odoo ERP Modules — All 25 apps" description="All 25 Odoo ERP modules we deploy and customize — Sales, CRM, Inventory, Purchase, Accounting, HR, Payroll, MRP, POS, Website, eCommerce, and more.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Odoo ERP Modules</div>
        <h1 class="h1 mt-4">25 Odoo apps. Deployed at production scale.</h1>
        <p class="lede mt-6 text-ink-300">From Sales to MRP, Payroll to POS — every Odoo module you need, configured by engineers who've shipped each one to production.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site space-y-14">
      {Object.entries(modByCat).map(([cat, list]) => (
        <div>
          <h2 class="h3">{cat}</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {list.map(m => (
              <a href={`/modules/${m.slug}/`} class="card group">
                <div class="flex items-center gap-3">
                  <span class="text-2xl">{m.icon}</span>
                  <h3 class="text-lg font-semibold">{m.title}</h3>
                </div>
                <p class="mt-3 text-sm text-ink-600">{m.tagline}</p>
                <span class="mt-4 inline-block text-sm font-semibold text-brand-600 group-hover:text-brand-700">Learn more →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
