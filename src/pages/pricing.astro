---
import Base from '~/layouts/Base.astro';
import { PRICING, FAQS } from '~/data/site';
---
<Base title="Pricing — Transparent Odoo project pricing" description="Transparent Odoo implementation pricing. Starter from $4,900, Growth from $14,900, Enterprise custom. Fixed-price or T&M.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="eyebrow text-brand-300">Pricing</div>
        <h1 class="h1 mt-4">Transparent pricing. No surprise invoices.</h1>
        <p class="lede mt-6 text-ink-300">Fixed-price scopes for well-defined projects. Honest T&M for exploratory or evolving work. Your choice.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-5 lg:grid-cols-3 max-w-6xl mx-auto">
        {PRICING.map(t => (
          <div class={`rounded-2xl p-8 ${t.highlight ? 'bg-odoo-gradient text-white ring-4 ring-brand-200' : 'bg-white border border-ink-200'}`}>
            <h2 class={`text-2xl font-bold ${t.highlight ? 'text-white' : 'text-ink-900'}`}>{t.name}</h2>
            <p class={`mt-2 text-sm ${t.highlight ? 'text-brand-100' : 'text-ink-600'}`}>{t.desc}</p>
            <div class="mt-6">
              <div class={`text-4xl font-bold ${t.highlight ? 'text-white' : 'text-brand-700'}`}>{t.price}</div>
              <div class={`text-sm ${t.highlight ? 'text-brand-100' : 'text-ink-500'} mt-1`}>{t.period}</div>
            </div>
            <ul class="mt-8 space-y-3">
              {t.features.map(f => (
                <li class="flex gap-2 text-sm">
                  <span class={t.highlight ? 'text-accent-300' : 'text-brand-600'}>✓</span>
                  <span class={t.highlight ? 'text-brand-100' : 'text-ink-700'}>{f}</span>
                </li>
              ))}
            </ul>
            <a href="/contact/" class={`mt-8 block text-center ${t.highlight ? 'btn-primary bg-white !text-brand-700 hover:bg-brand-50' : 'btn-secondary'}`}>{t.cta}</a>
          </div>
        ))}
      </div>

      <p class="mt-10 text-center text-sm text-ink-600">All prices USD. Detailed quotes after 30-min discovery call. NDA available.</p>
    </div>
  </section>

  <section class="section bg-ink-50 border-t border-ink-100">
    <div class="container-site max-w-4xl">
      <h2 class="h2 text-center">Pricing FAQ</h2>
      <div class="mt-10 space-y-3">
        {FAQS.slice(0,6).map(f => (
          <details class="group rounded-xl border border-ink-200 bg-white open:border-brand-200">
            <summary class="flex cursor-pointer items-center justify-between p-5 font-semibold">
              <span>{f.q}</span>
              <span class="text-brand-600 group-open:rotate-45 transition">+</span>
            </summary>
            <p class="px-5 pb-5 text-ink-700">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>
