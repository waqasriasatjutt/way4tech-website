---
import Base from '~/layouts/Base.astro';
import { PRODUCTS } from '~/data/site';

const categories = [...new Set(PRODUCTS.map(p => p.category))];
---
<Base
  title="Products — Odoo Modules by Way4Tech"
  description="20+ production-ready Odoo modules: HRMS suite, SaaS Kit, dashboards, POS customizations, industry solutions. Install what you need."
>
  <section class="bg-gradient-to-br from-brand-950 to-brand-800 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-200">Products</div>
        <h1 class="h1 mt-4">20+ Odoo modules. One vendor.</h1>
        <p class="lede mt-6 text-ink-100">Battle-tested modules covering HR, payroll, SaaS operations, POS, dashboards, and industry-specific workflows. Clean code, no Enterprise dependencies (unless you need them).</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      {categories.map(cat => (
        <div class="mb-16">
          <h2 class="h3 mb-6 flex items-center gap-3">
            {cat}
            <span class="text-sm font-normal text-ink-500">({PRODUCTS.filter(p => p.category === cat).length})</span>
          </h2>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {PRODUCTS.filter(p => p.category === cat).map(p => (
              <a href={`/products/${p.slug}/`} class="card group flex flex-col">
                <h3 class="text-lg font-semibold">{p.title}</h3>
                <p class="mt-2 text-sm text-ink-600 flex-1">{p.tagline}</p>
                <span class="mt-4 text-sm font-medium text-brand-600 group-hover:text-brand-700">Details →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
