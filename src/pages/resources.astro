---
import Base from '~/layouts/Base.astro';
import { FAQS } from '~/data/site';

const guides = [
  { title: 'Odoo Community vs Enterprise', href: '/blog/community-vs-enterprise/', desc: 'When to pay for Enterprise, when to stick with Community.' },
  { title: 'Best HRMS for Pakistan', href: '/blog/best-hrms-pakistan/', desc: 'FBR, EOBI, PF, SESSI — what a compliant HRMS looks like.' },
  { title: 'Run your own Odoo SaaS', href: '/blog/run-odoo-saas/', desc: 'How to turn one server into a multi-tenant Odoo SaaS.' },
  { title: 'ZATCA Phase 2 readiness', href: '/countries/saudi-arabia/', desc: 'Clearance, QR signing, XML — production checklist.' },
  { title: 'Odoo upgrade playbook', href: '/services/odoo-migration/', desc: 'Safe upgrade from any Odoo version to the latest.' },
  { title: 'Running Odoo on Docker', href: '/services/odoo-saas-hosting/', desc: 'Production-grade Odoo on Docker + Cloudflare.' },
];
---
<Base title="Resources — Odoo guides, FAQs, playbooks" description="Odoo guides, playbooks, FAQs, and resources for founders, CTOs, and finance teams evaluating or running Odoo.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Resources</div>
        <h1 class="h1 mt-4">Odoo guides, playbooks, and FAQs.</h1>
        <p class="lede mt-6 text-ink-300">Everything you need to evaluate, deploy, and scale Odoo — no fluff, no sales pitch.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <h2 class="h3">Guides</h2>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {guides.map(g => (
          <a href={g.href} class="card group">
            <h3 class="text-lg font-semibold">{g.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{g.desc}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 group-hover:text-brand-700">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50 border-t border-ink-100">
    <div class="container-site">
      <h2 class="h2">Frequently asked questions</h2>
      <div class="mt-10 max-w-4xl space-y-3">
        {FAQS.map(f => (
          <details class="group rounded-xl border border-ink-200 bg-white open:border-brand-200">
            <summary class="flex cursor-pointer items-center justify-between p-5 font-semibold">
              <span>{f.q}</span>
              <span class="text-brand-600 group-open:rotate-45 transition">+</span>
            </summary>
            <p class="px-5 pb-5 text-ink-700">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>
