---
import Base from '~/layouts/Base.astro';
import { SERVICES } from '~/data/site';

const categories = [...new Set(SERVICES.map(s => s.category))];
---
<Base
  title="Odoo Services — All 15 services"
  description="Full Odoo service catalog: implementation, customization, support, migration, integration, SaaS hosting, ZATCA e-invoicing, payroll, POS, e-commerce, localization across 18 countries."
>
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Services</div>
        <h1 class="h1 mt-4">Every Odoo service you need.</h1>
        <p class="lede mt-6 text-ink-300">15 productized Odoo services covering implementation, customization, SaaS hosting, compliance, localization, and more — delivered by senior engineers.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site space-y-14">
      {categories.map(cat => (
        <div>
          <h2 class="h3">{cat}</h2>
          <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {SERVICES.filter(s => s.category === cat).map(s => (
              <a href={`/services/${s.slug}/`} class="card group flex flex-col">
                <div class="text-3xl">{s.icon}</div>
                <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
                <p class="mt-2 text-sm text-ink-600 flex-1">{s.tagline}</p>
                <span class="mt-4 text-sm font-semibold text-brand-600 group-hover:text-brand-700">Learn more →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
