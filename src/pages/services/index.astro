---
import Base from '~/layouts/Base.astro';
import { SERVICES } from '~/data/site';
---
<Base
  title="Odoo Services — Implementation, Customization, Support"
  description="Full-stack Odoo services: implementation, customization, support, hire developer, integration, migration, consultancy, training. Trusted across Pakistan and the GCC."
>
  <section class="bg-gradient-to-br from-brand-950 to-brand-800 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-200">Services</div>
        <h1 class="h1 mt-4">Everything you need to run Odoo.</h1>
        <p class="lede mt-6 text-ink-100">From a one-off custom module to a multi-country rollout — we handle every part of your Odoo journey.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} class="card group flex flex-col">
            <div class="text-4xl">{s.icon}</div>
            <h3 class="mt-4 text-xl font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-600 flex-1">{s.short}</p>
            <span class="mt-5 text-sm font-medium text-brand-600 group-hover:text-brand-700">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
