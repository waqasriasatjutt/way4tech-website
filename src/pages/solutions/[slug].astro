---
import Base from '~/layouts/Base.astro';
import { SITE, SOLUTIONS } from '~/data/site';

export function getStaticPaths() {
  return SOLUTIONS.map(s => ({ params: { slug: s.slug }, props: { sol: s } }));
}

const { sol } = Astro.props;
const related = SOLUTIONS.filter(s => s.slug !== sol.slug).slice(0, 6);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: `Odoo for ${sol.title}`,
    provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
    description: sol.short,
    areaServed: SITE.locations,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: `${SITE.url}/solutions/` },
      { '@type': 'ListItem', position: 3, name: sol.title, item: `${SITE.url}/solutions/${sol.slug}/` },
    ],
  },
];
---
<Base
  title={`Odoo for ${sol.title}`}
  description={`${sol.short} Odoo Gold Partner with 500+ deployments across 18 countries.`}
  structuredData={schema}
>
  <section class="bg-odoo-gradient text-white">
    <div class="container-site py-16 sm:py-24">
      <nav class="text-sm text-brand-200"><a href="/" class="hover:text-white">Home</a> / <a href="/solutions/" class="hover:text-white">Solutions</a> / <span class="text-white">{sol.title}</span></nav>
      <div class="mt-6 max-w-3xl">
        <div class="text-5xl">{sol.icon}</div>
        <h1 class="h1 mt-6">Odoo for {sol.title}</h1>
        <p class="lede mt-6 text-brand-100">{sol.tagline}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-14 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <p class="text-lg text-ink-700">{sol.short}</p>

          <h2 class="h3 mt-12">Core features</h2>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {sol.features.map(f => (
              <li class="flex gap-3">
                <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-100 text-brand-700 text-xs font-bold">✓</span>
                <span class="text-ink-700">{f}</span>
              </li>
            ))}
          </ul>

          <h2 class="h3 mt-14">Why Way4Tech for {sol.title.toLowerCase()}</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {[
              {t:'Deep domain expertise', d:`We've deployed Odoo for ${sol.title.toLowerCase()} across multiple countries and scales.`},
              {t:'Localization built in', d:'Tax, e-invoicing, labor law — compliant from day one.'},
              {t:'Community-friendly', d:'Runs on Odoo Community where possible. Enterprise only if it pays off.'},
              {t:'Long-term partnership', d:'We stay involved. 5+ year client relationships are our norm.'},
            ].map(x => (
              <div class="card">
                <h3 class="font-semibold">{x.t}</h3>
                <p class="mt-2 text-sm text-ink-600">{x.d}</p>
              </div>
            ))}
          </div>
        </div>

        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <div class="rounded-2xl bg-odoo-gradient p-6 text-white">
              <h3 class="text-lg font-semibold">Scope a project</h3>
              <p class="mt-2 text-sm text-brand-100">Free 30-min consultation. Fixed-price or T&M.</p>
              <a href={`/contact/?service=${encodeURIComponent('Odoo for ' + sol.title)}&source=solutions/${sol.slug}`} class="btn-primary w-full mt-5 bg-white !text-brand-700 hover:bg-brand-50">Get a quote</a>
            </div>
            <div class="rounded-2xl bg-ink-50 p-6">
              <h3 class="text-sm font-semibold">Other industries</h3>
              <ul class="mt-4 space-y-2">
                {related.map(r => (
                  <li><a class="text-sm text-ink-700 hover:text-brand-600" href={`/solutions/${r.slug}/`}>{r.icon} {r.title}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
