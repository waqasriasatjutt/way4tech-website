---
import Base from '~/layouts/Base.astro';
import { SOLUTIONS } from '~/data/site';
---
<Base title="Industry Solutions — 20 Odoo industries" description="Odoo solutions for hospitals, clinics, pharmacies, restaurants, retail, construction, real estate, schools, logistics, manufacturing, salons, and more.">
  <section class="bg-ink-900 text-white">
    <div class="container-site py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="eyebrow text-brand-300">Industry Solutions</div>
        <h1 class="h1 mt-4">Odoo, tailored for your industry.</h1>
        <p class="lede mt-6 text-ink-300">20 industry-ready Odoo solutions — built from hundreds of real deployments in healthcare, retail, construction, education, logistics, and more.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {SOLUTIONS.map(s => (
          <a href={`/solutions/${s.slug}/`} class="card group">
            <div class="flex items-center gap-3">
              <span class="text-3xl">{s.icon}</span>
              <h2 class="text-lg font-semibold">{s.title}</h2>
            </div>
            <p class="mt-3 text-sm text-ink-600">{s.tagline}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 group-hover:text-brand-700">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
